# ===== 复制为 .env 并填写 =====

# ---- 站点 ----
SITE_TITLE=AI 技术雷达
SITE_URL=http://你的域名或IP:8000
TIMEZONE=Asia/Shanghai
# 网页「设置」页密码（用户名固定 admin），可在线切换模型/base_url/key，保存即生效
# 留空 = 禁用设置页。注意：HTTP Basic 认证建议配合 HTTPS 使用
ADMIN_PASSWORD=

# ---- LLM（provider 可选: anthropic | openai_compat | mock）----
# 以下是「默认值」；网页 /settings 中保存的配置优先于这里，且每个角色可独立 base_url+key
# 默认：Claude Haiku 粗筛 + Claude Sonnet 精讲，DeepSeek 兜底
SCORER_PROVIDER=anthropic
SCORER_MODEL=claude-haiku-4-5
EXPLAINER_PROVIDER=anthropic
EXPLAINER_MODEL=claude-sonnet-4-6
FALLBACK_PROVIDER=openai_compat
FALLBACK_MODEL=deepseek-chat

ANTHROPIC_API_KEY=sk-ant-xxxx
# DeepSeek 或其他 OpenAI 兼容端点（Qwen/Kimi/智谱改 BASE_URL 和 MODEL 即可）
OPENAI_COMPAT_API_KEY=sk-xxxx
OPENAI_COMPAT_BASE_URL=https://api.deepseek.com/v1

# 想全用 DeepSeek 省钱？这样改：
# SCORER_PROVIDER=openai_compat
# SCORER_MODEL=deepseek-chat
# EXPLAINER_PROVIDER=openai_compat
# EXPLAINER_MODEL=deepseek-chat

# ---- 采集 ----
# 强烈建议填：无 token 时 GitHub API 限额很低（60次/小时）
GITHUB_TOKEN=
COLLECT_LANGUAGES=python,typescript,rust,go
HN_QUERY_KEYWORDS=LLM,AI,GPT,Claude,agent,RAG,diffusion,transformer
ARXIV_CATEGORIES=cs.AI,cs.CL,cs.LG

# ---- 成本主开关 ----
EXPLAIN_LIMIT=12          # 每天深度讲解条数（12 条 ≈ $12/月，按需调）
MIN_SCORE_KEEP=5.0        # 低于此分丢弃

# ---- 语义去重（8GB 内存推荐开启；小内存 VPS 设为 false）----
EMBEDDING_ENABLED=true
EMBEDDING_MODEL=BAAI/bge-m3

# ---- 每日推送（可选，配了就推；两个渠道互不影响）----
# Telegram：找 @BotFather 建 bot 拿 token；找 @userinfobot 拿自己的 chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 邮件（SMTP）：QQ邮箱/163/Gmail 等的 SMTP 地址与「授权码」（不是登录密码）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
MAIL_TO=
NOTIFY_TOP_N=8

# ---- 调度（容器内时区）----
PIPELINE_CRON=0 9,21 * * *
WEEKLY_CRON=30 21 * * 0
